(static_site) {
	root * /usr/share/caddy

	handle /health {
		respond "ok" 200
	}

	try_files {path} {path}/ /index.html
	file_server
}

:80 {
	handle_path /agent/* {
		reverse_proxy agent:3001
	}

	handle /api* {
		reverse_proxy agent:3001
	}

	handle /webhooks/telegram* {
		reverse_proxy agent:3001
	}

	import static_site
}
