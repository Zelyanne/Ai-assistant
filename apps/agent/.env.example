# Supabase
SUPABASE_URL_PROJECT_GOOGLE_ASSITANT=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY_PROJECT_GOOGLE_ASSITANT=your_service_role_key

# LLM providers
MISTRAL_API_KEY_PROJECT_GOOGLE_ASSITANT=your_mistral_api_key
DEFAULT_LLM_MODEL_PROJECT_GOOGLE_ASSITANT=mistral-small-latest
OPENAI_API_KEY_PROJECT_GOOGLE_ASSITANT=optional_openai_api_key
ANTHROPIC_API_KEY_PROJECT_GOOGLE_ASSITANT=optional_anthropic_api_key

# SearXNG MCP research
SEARXNG_MCP_URL_PROJECT_GOOGLE_ASSITANT=http://127.0.0.1:3100/mcp
SEARXNG_URL_PROJECT_GOOGLE_ASSITANT=http://127.0.0.1:8081
SEARXNG_MCP_USERNAME_PROJECT_GOOGLE_ASSITANT=
SEARXNG_MCP_PASSWORD_PROJECT_GOOGLE_ASSITANT=

# Runtime
PORT_PROJECT_GOOGLE_ASSITANT=3001
NODE_ENV_PROJECT_GOOGLE_ASSITANT=development
CONFIDENCE_THRESHOLD_PROJECT_GOOGLE_ASSITANT=0.8
CRON_POLL_INTERVAL_MS_PROJECT_GOOGLE_ASSITANT=60000
DEFAULT_TIMEZONE_PROJECT_GOOGLE_ASSITANT=UTC
MAX_SCHEDULE_FAILURES_PROJECT_GOOGLE_ASSITANT=3
EOD_TRIGGER_TIME_UTC_PROJECT_GOOGLE_ASSITANT=23:00
EOD_TRIGGER_TIME_BY_ORG_JSON_PROJECT_GOOGLE_ASSITANT={"org-demo":"22:30"}
INGESTION_MAX_RESULTS_PROJECT_GOOGLE_ASSITANT=20
GMAIL_THREAD_DETAIL_CONCURRENCY_PROJECT_GOOGLE_ASSITANT=4
TRIAGE_BATCH_INPUT_TOKENS_PROJECT_GOOGLE_ASSITANT=13000
TRIAGE_BATCH_CONCURRENCY_PROJECT_GOOGLE_ASSITANT=1
TRIAGE_BATCH_OUTPUT_TOKENS_PROJECT_GOOGLE_ASSITANT=1800

# Google Workspace OAuth
GOOGLE_OAUTH_CLIENT_ID_PROJECT_GOOGLE_ASSITANT=your_google_oauth_client_id
GOOGLE_OAUTH_CLIENT_SECRET_PROJECT_GOOGLE_ASSITANT=your_google_oauth_client_secret
GOOGLE_OAUTH_REDIRECT_URI_PROJECT_GOOGLE_ASSITANT=http://localhost:3001/api/auth/google/callback

# Exactly 32 characters
ENCRYPTION_SECRET_PROJECT_GOOGLE_ASSITANT=replace_with_32_character_secret

# Telegram Bot
TELEGRAM_BOT_TOKEN_PROJECT_GOOGLE_ASSITANT=your_telegram_bot_token
TELEGRAM_BOT_USERNAME_PROJECT_GOOGLE_ASSITANT=your_bot_username_without_at
TELEGRAM_WEBHOOK_SECRET_PROJECT_GOOGLE_ASSITANT=your_telegram_webhook_secret
TELEGRAM_WEBHOOK_URL_PROJECT_GOOGLE_ASSITANT=https://your-agent-domain/webhooks/telegram

# WhatsApp provider selection: auto | evolution | meta | twilio
WHATSAPP_PROVIDER_PROJECT_GOOGLE_ASSITANT=auto

# WhatsApp (Evolution API - recommended current default)
EVOLUTION_API_BASE_URL_PROJECT_GOOGLE_ASSITANT=https://your-evolution-host
EVOLUTION_API_KEY_PROJECT_GOOGLE_ASSITANT=your_evolution_api_key
EVOLUTION_INSTANCE_NAME_PROJECT_GOOGLE_ASSITANT=your_instance_name
EVOLUTION_WEBHOOK_SECRET_PROJECT_GOOGLE_ASSITANT=your_evolution_webhook_secret

# WhatsApp (Meta Cloud API)
WHATSAPP_API_KEY_PROJECT_GOOGLE_ASSITANT=your_whatsapp_api_token
WHATSAPP_PHONE_NUMBER_ID_PROJECT_GOOGLE_ASSITANT=your_phone_number_id
WHATSAPP_WEBHOOK_SECRET_PROJECT_GOOGLE_ASSITANT=your_whatsapp_webhook_secret

# WhatsApp (Twilio)
TWILIO_ACCOUNT_SID_PROJECT_GOOGLE_ASSITANT=your_twilio_account_sid
TWILIO_AUTH_TOKEN_PROJECT_GOOGLE_ASSITANT=your_twilio_auth_token
TWILIO_WHATSAPP_PHONE_NUMBER_PROJECT_GOOGLE_ASSITANT=whatsapp:+14155238886

# Langfuse (primary tracing)
ENABLE_LANGFUSE_TRACING_PROJECT_GOOGLE_ASSITANT=false
LANGFUSE_PUBLIC_KEY_PROJECT_GOOGLE_ASSITANT=optional_langfuse_public_key
LANGFUSE_SECRET_KEY_PROJECT_GOOGLE_ASSITANT=optional_langfuse_secret_key
LANGFUSE_HOST_PROJECT_GOOGLE_ASSITANT=https://cloud.langfuse.com

# LangSmith (legacy/deprecated fallback)
LANGSMITH_TRACING_PROJECT_GOOGLE_ASSITANT=false
LANGSMITH_ENDPOINT_PROJECT_GOOGLE_ASSITANT=https://api.smith.langchain.com
LANGSMITH_API_KEY_PROJECT_GOOGLE_ASSITANT=optional_langsmith_api_key
LANGSMITH_PROJECT_PROJECT_GOOGLE_ASSITANT=ai-assistant
