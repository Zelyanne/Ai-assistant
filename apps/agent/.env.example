# Supabase
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# LLM providers
MISTRAL_API_KEY=your_mistral_api_key
DEFAULT_LLM_MODEL=mistral-small-latest
OPENAI_API_KEY=optional_openai_api_key
ANTHROPIC_API_KEY=optional_anthropic_api_key

# SearXNG MCP research
SEARXNG_MCP_URL=http://127.0.0.1:3000/mcp
SEARXNG_URL=http://127.0.0.1:8080
SEARXNG_MCP_USERNAME=
SEARXNG_MCP_PASSWORD=

# Runtime
PORT=3001
NODE_ENV=development
CONFIDENCE_THRESHOLD=0.8
CRON_POLL_INTERVAL_MS=60000
DEFAULT_TIMEZONE=UTC
MAX_SCHEDULE_FAILURES=3
EOD_TRIGGER_TIME_UTC=23:00
EOD_TRIGGER_TIME_BY_ORG_JSON={"org-demo":"22:30"}

# Google Workspace OAuth
GOOGLE_OAUTH_CLIENT_ID=your_google_oauth_client_id
GOOGLE_OAUTH_CLIENT_SECRET=your_google_oauth_client_secret
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3001/api/auth/google/callback

# Exactly 32 characters
ENCRYPTION_SECRET=replace_with_32_character_secret

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_BOT_USERNAME=your_bot_username_without_at
TELEGRAM_WEBHOOK_SECRET=your_telegram_webhook_secret

# WhatsApp provider selection: auto | evolution | meta | twilio
WHATSAPP_PROVIDER=auto

# WhatsApp (Evolution API - recommended current default)
EVOLUTION_API_BASE_URL=https://your-evolution-host
EVOLUTION_API_KEY=your_evolution_api_key
EVOLUTION_INSTANCE_NAME=your_instance_name
EVOLUTION_WEBHOOK_SECRET=your_evolution_webhook_secret

# WhatsApp (Meta Cloud API)
WHATSAPP_API_KEY=your_whatsapp_api_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_WEBHOOK_SECRET=your_whatsapp_webhook_secret

# WhatsApp (Twilio)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_PHONE_NUMBER=whatsapp:+14155238886

# Langfuse (primary tracing)
ENABLE_LANGFUSE_TRACING=false
LANGFUSE_PUBLIC_KEY=optional_langfuse_public_key
LANGFUSE_SECRET_KEY=optional_langfuse_secret_key
LANGFUSE_HOST=https://cloud.langfuse.com

# LangSmith (legacy/deprecated fallback)
LANGSMITH_TRACING=false
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=optional_langsmith_api_key
LANGSMITH_PROJECT=ai-assistant
