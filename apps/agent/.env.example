# Supabase
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# LLM providers
MISTRAL_API_KEY=your_mistral_api_key
DEFAULT_LLM_MODEL=mistral-small-latest
OPENAI_API_KEY=optional_openai_api_key
ANTHROPIC_API_KEY=optional_anthropic_api_key

# Runtime
PORT=3001
NODE_ENV=development
CONFIDENCE_THRESHOLD=0.8

# Google Workspace OAuth
GOOGLE_OAUTH_CLIENT_ID=your_google_oauth_client_id
GOOGLE_OAUTH_CLIENT_SECRET=your_google_oauth_client_secret
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3001/api/auth/google/callback

# Exactly 32 characters
ENCRYPTION_SECRET=replace_with_32_character_secret

# Langfuse (primary tracing)
ENABLE_LANGFUSE_TRACING=false
LANGFUSE_PUBLIC_KEY=optional_langfuse_public_key
LANGFUSE_SECRET_KEY=optional_langfuse_secret_key
LANGFUSE_HOST=https://cloud.langfuse.com

# LangSmith (legacy/deprecated fallback)
LANGSMITH_TRACING=false
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=optional_langsmith_api_key
LANGSMITH_PROJECT=ai-assistant
